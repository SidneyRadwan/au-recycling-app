project_id = "your-gcp-project-id"
region     = "australia-southeast1"

# Cloud SQL JDBC URL — fill in after `terraform apply` creates the instance,
# or use the Cloud SQL Auth Proxy address for local/CI connections.
# database_url = "jdbc:postgresql:///<db-name>?cloudSqlInstance=<connection-name>&socketFactory=com.google.cloud.sql.postgres.SocketFactory"

# Sensitive values — do not commit actual secrets. Use CI/CD secrets or
# a secrets manager (e.g. Google Secret Manager, HashiCorp Vault).
# database_password  = "change-me"
# anthropic_api_key  = "sk-ant-..."

# DNS — update to match your registered domain
# dns_zone_name   = "australiarecycling.com.au"
# frontend_domain = "australiarecycling.com.au"
