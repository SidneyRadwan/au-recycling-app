# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/recycling

# Anthropic API key — used for LLM-assisted material extraction
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for extraction (default: claude-opus-4-6)
EXTRACTION_MODEL=claude-opus-4-6

# Directory where JSON output files are written (default: ./output)
SCRAPER_OUTPUT_DIR=./output

# Minimum seconds to wait between HTTP requests (default: 1.0)
SCRAPER_RATE_LIMIT=1.0

# Seed data source URLs — override if a government directory page moves
# SEED_NSW_URL=https://www.olg.nsw.gov.au/public/local-government-directory/
# SEED_VIC_URL=https://www.vic.gov.au/local-government-contacts-and-information
# SEED_QLD_URL=https://www.dlgwv.qld.gov.au/local-government/for-the-community/local-government-directory/search-the-local-government-directory
# SEED_QLD_API_URL=https://www.dlgwv.qld.gov.au/local-government/for-the-community/local-government-directory/lg-directory-config/get-lga-json?lgacode=
# SEED_WA_URL=https://mycouncil.wa.gov.au
# SEED_SA_URL=https://en.wikipedia.org/wiki/Local_government_areas_of_South_Australia
# SEED_TAS_URL=https://en.wikipedia.org/wiki/Local_government_areas_of_Tasmania
# SEED_NT_URL=https://nt.gov.au/community/local-councils-remote-communities-and-homelands/find-your-council
# SEED_POSTCODES_URL=https://raw.githubusercontent.com/matthewproctor/australianpostcodes/master/australian_postcodes.csv
