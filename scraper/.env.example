# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/recycling

# Anthropic API key — used for LLM-assisted material extraction
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for extraction (default: claude-opus-4-6)
EXTRACTION_MODEL=claude-opus-4-6

# Directory where JSON output files are written (default: ./output)
SCRAPER_OUTPUT_DIR=./output

# Minimum seconds to wait between HTTP requests (default: 1.0)
SCRAPER_RATE_LIMIT=1.0
