  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cd *)",
      "Bash(mkdir *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(pwd)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(docker-compose ps *)",
      "Bash(docker-compose logs *)",
      "Bash(docker ps *)",
      "Bash(gradle tasks *)",
      "Bash(gradle test *)",
      "Bash(gradle build *)",
      "Bash(npm run lint *)",
      "Bash(npm run test *)",
      "Bash(npm run build *)",
      "Bash(npx next lint *)",
      "Bash(python -m pytest *)"
