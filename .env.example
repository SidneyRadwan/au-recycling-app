# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/recycling
DATABASE_USERNAME=recycling
DATABASE_PASSWORD=recycling_dev

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LiteLLM proxy
# Model to route through the proxy — swap without changing application code
LITELLM_DEFAULT_MODEL=claude-sonnet-4-6
# API key forwarded to the upstream provider (e.g. your Anthropic key)
LITELLM_API_KEY=sk-ant-your-key-here
# Master key the backend uses to authenticate to the LiteLLM proxy
LITELLM_MASTER_KEY=dev-master-key

# Feature flags
ENABLE_AI_AGENT=false

# Scraper
SCRAPER_OUTPUT_DIR=./output
SCRAPER_RATE_LIMIT=2
