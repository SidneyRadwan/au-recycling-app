# Database
# In devcontainer: db:5432 (Docker network). Local without Docker: localhost:5432
DATABASE_URL=jdbc:postgresql://db:5432/recycling
DATABASE_USERNAME=recycling
DATABASE_PASSWORD=recycling_dev

# Spring profile: "local" (H2, no Postgres) or "dev" (Postgres)
SPRING_PROFILES_ACTIVE=local

FIGMA_ACCESS_TOKEN=

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LiteLLM proxy
# Model to route through the proxy — swap without changing application code
LITELLM_DEFAULT_MODEL=claude-sonnet-4-6
# Master key the backend uses to authenticate to the LiteLLM proxy
LITELLM_MASTER_KEY=dev-master-key
